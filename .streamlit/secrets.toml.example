# Exemple de fichier de secrets pour l'application.
#
# EN LOCAL (facultatif) : copiez ce fichier en ".streamlit/secrets.toml"
# et collez votre URL Supabase pour tester la base en ligne depuis votre PC.
# Sans ce fichier, l'application utilise automatiquement une base SQLite locale.
#
# SUR STREAMLIT COMMUNITY CLOUD : ne versionnez PAS de secrets. Renseignez la
# même clé via l'interface "App settings > Secrets" (voir le README).
#
# Collez l'URL de connexion "Session pooler" de Supabase (port 5432) :
DATABASE_URL = "postgresql://postgres.xxxxxxxxxxxx:[email protected]:5432/postgres"
