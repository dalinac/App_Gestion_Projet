# Exemple de secrets pour l'application.
#
# EN LOCAL (facultatif) : copiez ce fichier en ".streamlit/secrets.toml" pour
# tester la base en ligne depuis votre PC. Sans ce fichier, l'application
# utilise automatiquement une base SQLite locale.
#
# SUR STREAMLIT COMMUNITY CLOUD : ne versionnez PAS de secrets. Renseignez les
# mêmes valeurs via "App settings > Secrets" (voir le README).
#
# Deux formats possibles. Le format par champs séparés (recommandé) évite tout
# problème si le mot de passe contient des caractères spéciaux (@ : / # ? ...).

# --- Format recommandé : champs séparés ---------------------------------
# Récupérez ces valeurs dans Supabase : Connect > Connection string >
# "Session pooler" (port 5432, compatible IPv4 requis par Streamlit Cloud).
[postgres]
host = "aws-0-eu-central-1.pooler.supabase.com"
port = 5432
user = "postgres.xxxxxxxxxxxx"
password = "votre_mot_de_passe"
dbname = "postgres"

# --- OU format URL unique (alternative) ---------------------------------
# Laissez la section [postgres] ci-dessus commentée si vous utilisez celui-ci.
# DATABASE_URL = "postgresql://postgres.xxxxxxxxxxxx:[email protected]:5432/postgres"
