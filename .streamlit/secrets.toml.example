# Exemple de secrets pour l'application.
#
# EN LOCAL (facultatif) : copiez ce fichier en ".streamlit/secrets.toml" pour
# tester le stockage persistant depuis votre PC. Sans ce fichier, l'application
# utilise automatiquement un fichier JSON local (data/gestion_projet.json).
#
# SUR STREAMLIT COMMUNITY CLOUD : ne versionnez PAS de secrets. Renseignez les
# mêmes valeurs via "App settings > Secrets" (voir le README).

# --- Stockage persistant : GitHub Gist ----------------------------------
# 1. Créez un gist PRIVÉ sur https://gist.github.com avec un fichier nommé
#    "gestion_projet.json" dont le contenu est : {}
# 2. L'identifiant du gist (gist_id) est la dernière partie de son URL :
#    https://gist.github.com/<user>/<gist_id>
# 3. Créez un token GitHub avec la portée "gist" :
#    - Token classique : https://github.com/settings/tokens (cochez "gist")
#    - Token "fine-grained" : autorisez l'accès "Gists" en lecture/écriture.
[github]
token = "ghp_votre_token_personnel"
gist_id = "abcdef0123456789abcdef0123456789"
